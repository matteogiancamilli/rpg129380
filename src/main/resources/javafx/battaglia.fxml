<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720" prefWidth="700" stylesheets="@battaglia.css" xmlns="http://javafx.com/javafx/25.0.3" xmlns:fx="http://javafx.com/fxml/1" fx:controller="it.unicam.cs.mpgc.rpg129380.controller.ControllerBattaglia">
    <center>
        <HBox alignment="CENTER" spacing="120">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>
            <VBox alignment="CENTER" spacing="8">
                <Label fx:id="nomeGiocatore" styleClass="battle-name-label" />
                <ImageView fx:id="immagineGiocatore" fitHeight="150" fitWidth="150" preserveRatio="true" />
                <ProgressBar fx:id="hpBarGiocatore" prefWidth="150" progress="1.0" styleClass="hp-green" />
                <Label fx:id="hpLabelGiocatore" />
            </VBox>
            <VBox alignment="CENTER" spacing="8">
                <Label fx:id="nomeMostro" styleClass="battle-name-label" />
                <ImageView fx:id="immagineMostro" fitHeight="150" fitWidth="150" preserveRatio="true" />
                <ProgressBar fx:id="hpBarMostro" prefWidth="150" progress="1.0" styleClass="hp-green" />
                <Label fx:id="hpLabelMostro" />
            </VBox>
        </HBox>
    </center>
    <bottom>
        <VBox spacing="6">
            <padding>
                <Insets bottom="10" left="10" right="10" top="10" />
            </padding>
            <Label fx:id="battleLog" styleClass="battle-log" wrapText="true">
                <padding>
                    <Insets bottom="8" left="8" right="8" top="8" />
                </padding>
            </Label>
            <TabPane tabClosingPolicy="UNAVAILABLE">
                <tabs>
                    <Tab text="Abilità">
                        <VBox spacing="6">
                            <padding>
                                <Insets bottom="8" left="8" right="8" top="8" />
                            </padding>
                            <Label fx:id="manaLabel" styleClass="mana-label" />
                            <Label fx:id="descrizioneAbilita" styleClass="descrizione-abilita" text=" " wrapText="true" />
                            <VBox fx:id="abilitaBox" spacing="6">
                                <padding>
                                    <Insets bottom="8" left="8" right="8" top="8" />
                                </padding>
                            </VBox>
                        </VBox>
                    </Tab>
                    <Tab text="Oggetti">
                        <VBox spacing="6">
                            <padding>
                                <Insets bottom="4" left="4" right="4" top="4" />
                            </padding>
                            <FlowPane fx:id="oggettiPane" hgap="8" prefWrapLength="380" vgap="8">
                                <padding>
                                    <Insets bottom="8" left="8" right="8" top="8" />
                                </padding>
                            </FlowPane>
                            <Label fx:id="labelOggetto" styleClass="label-oggetto" text=" " wrapText="true" />
                        </VBox>
                    </Tab>
                </tabs>
            </TabPane>
        </VBox>
    </bottom>
</BorderPane>